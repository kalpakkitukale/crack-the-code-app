    "suggest_break": {
      "trigger": "After 3 videos watched in a single session",
      "action": "Suggest taking a 5-minute break before continuing"
    },
    "recommend_practice": {
      "trigger": "Student completes videos but scores < 70% on checkpoint",
      "action": "Recommend practicing 10-15 problems with parent/teacher"
    },
    "recommend_retake": {
      "trigger": "Student in not_ready category completes all prerequisite videos",
