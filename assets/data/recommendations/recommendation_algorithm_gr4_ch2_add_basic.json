            "explanation": "Add the ten thousands: 2+1=3, thousands: 3+2=5 → 35,000."
          }
        ],
        "ifCorrect": {
          "action": "unlock_challenge",
          "unlockVideoId": "gr4_add_v6",
          "reason": "Student ready for mental math strategies"
