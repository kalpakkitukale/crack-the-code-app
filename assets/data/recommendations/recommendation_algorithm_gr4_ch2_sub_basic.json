    "commonChallenges": {
      "challenge1": "Students not aligning numbers properly by place value",
      "solution1": "Emphasize writing numbers in columns with ones under ones, tens under tens, etc. Use graph paper for practice",
      "challenge2": "Students subtracting smaller from larger regardless of position",
      "solution2": "Teach systematic approach: always subtract bottom from top. If bottom is larger, need regrouping (taught in next topic)",
      "challenge3": "Students making careless errors with subtraction facts",
      "solution3": "Review subtraction facts, practice mental math, encourage checking work using addition (answer + bottom = top)"
    }
