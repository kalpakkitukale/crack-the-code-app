# StreamShaala Environment Configuration
# Copy this file to .env and fill in your values
# These values can be passed at build time using --dart-define

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Google OAuth Web Client ID (from Firebase Console)
# Required for Android to get idToken for Firebase Auth
# Find this in: Firebase Console > Project Settings > General > Web API Key
GOOGLE_WEB_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Apple Sign-In Service ID (from Apple Developer Portal)
# Required for Apple Sign-In on iOS and web
APPLE_SERVICE_ID=com.yourcompany.streamshaala

# =============================================================================
# CONTENT DELIVERY
# =============================================================================

# Cloudflare R2 bucket URL for content delivery
# This is where educational content (videos, quizzes, etc.) is stored
CONTENT_BUCKET_URL=https://content.streamshaala.com

# Content version prefix for versioned content paths
CONTENT_VERSION=v1

# =============================================================================
# FIREBASE
# =============================================================================

# Firebase project configuration
# Note: Most Firebase config is in google-services.json (Android) and
# GoogleService-Info.plist (iOS). These are for web/desktop if needed.
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================

# Enable/disable analytics in development
ANALYTICS_ENABLED=false

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================

# Enable experimental features
ENABLE_LEARNING_PATHS=true
ENABLE_QUIZ_RECOMMENDATIONS=true
ENABLE_CLOUD_SYNC=true

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# App segment (junior, middle, preboard, senior)
# This determines which app variant to build
APP_SEGMENT=junior

# Environment (development, staging, production)
BUILD_ENV=development

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================
#
# Option 1: Using --dart-define at build time
# flutter run --dart-define=GOOGLE_WEB_CLIENT_ID=xxx --dart-define=BUILD_ENV=production
#
# Option 2: Using .env file with flutter_dotenv package
# Add flutter_dotenv to pubspec.yaml and load in main.dart
#
# Option 3: Platform-specific configuration
# - Android: Use BuildConfig fields in build.gradle.kts
# - iOS: Use xcconfig files
# - Web: Use environment variables in hosting platform
